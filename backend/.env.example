# StellarFlow Backend — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit the real .env to version control.

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgres://stellarflow:your_password_here@localhost:5432/stellarflow_db
DB_MAX_CONNECTIONS=50
DB_ACQUIRE_TIMEOUT_SECS=10

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── Server ───────────────────────────────────────────────────────────────────
BIND_ADDR=0.0.0.0:8080

# ─── Stellar Network ──────────────────────────────────────────────────────────
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Soroban RPC endpoint for Testnet.
STELLAR_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Horizon API endpoint for Testnet.
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Deployed TreasuryRouter Soroban contract ID.
TREASURY_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Master admin keypair (used as fallback and for org registration)
STELLAR_ADMIN_PUBLIC_KEY=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STELLAR_SIGNER_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Phase C.5: Treasury Wallet Signing Keys ─────────────────────────────────
# Stellar TESTNET secret keys for each treasury vault.
# These are read ONCE at startup, immediately encrypted with AES-256-GCM,
# and stored in the wallet_secrets table. They are NEVER stored in plaintext.
#
# Generate testnet keys: stellar keys generate --network testnet <name>
# Fund via Friendbot:    curl https://friendbot.stellar.org/?addr=<PUBLIC_KEY>
#
# The public keys MUST match those registered in the wallets table.
# (Default seed public keys are shown below for reference)
#
MASTER_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
PAYROLL_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
OPERATIONS_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RESERVE_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
MARKETING_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Cryptography ─────────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting wallet signing secrets at rest.
# Must decode to exactly 32 bytes.
# Generate: openssl rand -base64 32
AES_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# ─── Soroban Event Poller ────────────────────────────────────────────────────
SOROBAN_POLL_INTERVAL_MS=3000

# ─── Approval TTL ────────────────────────────────────────────────────────────
APPROVAL_TTL_HOURS=24

# ─── WebSocket ────────────────────────────────────────────────────────────────
BROADCAST_CHANNEL_CAPACITY=1024

# ─── Logging ──────────────────────────────────────────────────────────────────
RUST_LOG=stellarflow_backend=info,tower_http=info,axum=info
