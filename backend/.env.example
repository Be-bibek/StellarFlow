# StellarFlow Backend — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit the real .env to version control.

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgres://stellarflow:your_password_here@localhost:5432/stellarflow_db
DB_MAX_CONNECTIONS=50

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── Server ───────────────────────────────────────────────────────────────────
BIND_ADDR=0.0.0.0:8080

# ─── Stellar Network ──────────────────────────────────────────────────────────
# Soroban RPC endpoint for Testnet.
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Horizon API endpoint for Testnet.
HORIZON_URL=https://horizon-testnet.stellar.org

# Deployed TreasuryRouter Soroban contract ID.
TREASURY_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Organization admin keypair (keep SECRET — use Vault/KMS in production).
STELLAR_ADMIN_PUBLIC_KEY=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STELLAR_SIGNER_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Soroban Event Poller ────────────────────────────────────────────────────
# Polling interval in milliseconds (3000 = 3s, matches Stellar ledger close).
SOROBAN_POLL_INTERVAL_MS=3000

# ─── Approval TTL ────────────────────────────────────────────────────────────
# Default seconds before a multi-sig approval request expires.
APPROVAL_TTL_HOURS=24

# ─── Logging ──────────────────────────────────────────────────────────────────
RUST_LOG=stellarflow_backend=info,tower_http=info,axum=info
